# ─────────────────────────────────────────────────────────────
# .claudeignore — Claude Code가 읽지 않을 파일/디렉토리
# API 키·캐시·빌드 산출물을 컨텍스트에서 제외해 토큰 낭비 방지
# ─────────────────────────────────────────────────────────────

# 가상환경
.venv/
venv/
env/

# Python 캐시
__pycache__/
*.pyc
*.pyo
*.pyd

# 환경변수 (API 키 포함)
.env

# 로컬 JSON 캐시 (YouTube API 응답)
cache/*.json

# 빌드 산출물
dist/
build/
*.egg-info/

# macOS
.DS_Store
